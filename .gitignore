# Bot data and settings
bot_settings/
bot_data/
logs/

# Secret encryption key (never commit!)
.secret_key
*.secret_key

# Local backups (contain secrets — never commit!)
backups/

# Module runtime config and data (may contain tokens, api-keys, sold accounts,
# customer data — never commit!). Regenerated from code defaults on first run.
modules/*/module_settings/config.json
modules/*/module_data/

# Tooling caches
.pytest_cache/
.ruff_cache/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
.env

# IDE
.vscode/
.idea/
*.iml

# OS
.DS_Store
Thumbs.db

# Git
.git/

# Local auth helper with token
setup_git_auth.bat

# Release helper scripts (contain no secrets but optional locally)
create_release.bat
auto_push.bat
