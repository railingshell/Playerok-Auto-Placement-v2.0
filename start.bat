:box
set "text=%~1"
echo %LCYAN%????????????????????????????????????????????????????????????%RST%
echo %LCYAN%?%RST%  %BOLD%%LWHITE%%text%%RST%                                          %LCYAN%?%RST%
echo %LCYAN%????????????????????????????????????????????????????????????%RST%
goto :eof

:draw_progress
set "label=%~1"
set /a percent=%~2
set /a filled=%percent% / 2
set /a empty=50 - %filled%
set "bar="
for /l %%i in (1,1,%filled%) do set "bar=!bar!?"
for /l %%i in (1,1,%empty%) do set "bar=!bar!?"
echo %GRAY%  [ %RST%%LGREEN%%bar%%RST%%GRAY% ] %RST%%LWHITE%%percent%%%RST% %GRAY%- %label%%RST%
timeout /t 1 >nul
goto :eof
